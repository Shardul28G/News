{
  "name": "reader-news",
  "version": "1.0.0",
  "description": "Refactored news reader powered by Gemini",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "icon": "node scripts/generate-icon.mjs",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "@extractus/article-extractor": "^8.1.0",
    "rss-parser": "^3.13.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "png-to-ico": "^3.0.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sharp": "^0.34.5",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.reader.news",
    "productName": "Reader",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "linux": {
      "icon": "resources/icon.png",
      "target": "AppImage"
    },
    "mac": {
      "icon": "resources/icon.png",
      "target": "dmg"
    },
    "nsis": {
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "shortcutName": "Reader"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      { "from": "resources/icon.ico", "to": "icon.ico" },
      { "from": "resources/icon.png", "to": "icon.png" }
    ]
  }
}
