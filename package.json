{
  "name": "reader-news",
  "version": "1.0.0",
  "description": "Refactored news reader powered by Gemini",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "rss-parser": "^3.13.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.reader.news",
    "productName": "Reader",
    "directories": { "output": "dist" },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "files": ["out/**/*"]
  }
}
